package webhook

import (
	"crypto/hmac"
	"crypto/sha256"
	"encoding/base64"
	"errors"
	"net/http"
	"testing"
)

func flutterwaveSignature(secretHash string, body []byte) string {
	mac := hmac.New(sha256.New, []byte(secretHash))
	mac.Write(body)
	return base64.StdEncoding.EncodeToString(mac.Sum(nil))
}

func flutterwaveHeaders(secretHash string, body []byte) http.Header {
	h := make(http.Header)
	h.Set("flutterwave-signature", flutterwaveSignature(secretHash, body))
	return h
}

func TestProviderFlutterwaveValidSignatureAccepted(t *testing.T) {
	const secretHash = "fw_secret_hash"
	body := []byte(`{"event":"charge.completed"}`)

	v := ProviderFlutterwave(secretHash)
	if err := v.Verify(body, flutterwaveHeaders(secretHash, body)); err != nil {
		t.Fatalf("Verify: %v", err)
	}
}

func TestProviderFlutterwaveTamperedBodyRejected(t *testing.T) {
	const secretHash = "fw_secret_hash"
	signedBody := []byte(`{"event":"charge.completed"}`)
	tamperedBody := []byte(`{"event":"charge.failed"}`)

	v := ProviderFlutterwave(secretHash)
	err := v.Verify(tamperedBody, flutterwaveHeaders(secretHash, signedBody))
	if !errors.Is(err, ErrInvalidSignature) {
		t.Fatalf("Verify() error = %v, want ErrInvalidSignature", err)
	}
}

func TestProviderFlutterwaveWrongSecretRejected(t *testing.T) {
	body := []byte(`{"event":"charge.completed"}`)

	v := ProviderFlutterwave("fw_correct")
	err := v.Verify(body, flutterwaveHeaders("fw_wrong", body))
	if !errors.Is(err, ErrInvalidSignature) {
		t.Fatalf("Verify() error = %v, want ErrInvalidSignature", err)
	}
}

func TestProviderFlutterwaveMissingHeader(t *testing.T) {
	v := ProviderFlutterwave("fw_secret_hash")
	err := v.Verify([]byte("body"), make(http.Header))
	if !errors.Is(err, ErrMissingHeader) {
		t.Fatalf("Verify() error = %v, want ErrMissingHeader", err)
	}
}
