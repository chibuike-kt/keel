package webhook

import (
	"crypto/hmac"
	"crypto/sha512"
	"encoding/hex"
	"errors"
	"net/http"
	"testing"
)

func paystackSignature(secret string, body []byte) string {
	mac := hmac.New(sha512.New, []byte(secret))
	mac.Write(body)
	return hex.EncodeToString(mac.Sum(nil))
}

func paystackHeaders(secret string, body []byte) http.Header {
	h := make(http.Header)
	h.Set("x-paystack-signature", paystackSignature(secret, body))
	return h
}

func TestProviderPaystackValidSignatureAccepted(t *testing.T) {
	const secret = "sk_test_paystack"
	body := []byte(`{"event":"charge.success"}`)

	v := ProviderPaystack(secret)
	if err := v.Verify(body, paystackHeaders(secret, body)); err != nil {
		t.Fatalf("Verify: %v", err)
	}
}

func TestProviderPaystackTamperedBodyRejected(t *testing.T) {
	const secret = "sk_test_paystack"
	signedBody := []byte(`{"event":"charge.success"}`)
	tamperedBody := []byte(`{"event":"charge.failed"}`)

	v := ProviderPaystack(secret)
	err := v.Verify(tamperedBody, paystackHeaders(secret, signedBody))
	if !errors.Is(err, ErrInvalidSignature) {
		t.Fatalf("Verify() error = %v, want ErrInvalidSignature", err)
	}
}

func TestProviderPaystackWrongSecretRejected(t *testing.T) {
	body := []byte(`{"event":"charge.success"}`)

	v := ProviderPaystack("sk_correct")
	err := v.Verify(body, paystackHeaders("sk_wrong", body))
	if !errors.Is(err, ErrInvalidSignature) {
		t.Fatalf("Verify() error = %v, want ErrInvalidSignature", err)
	}
}

func TestProviderPaystackMissingHeader(t *testing.T) {
	v := ProviderPaystack("sk_test_paystack")
	err := v.Verify([]byte("body"), make(http.Header))
	if !errors.Is(err, ErrMissingHeader) {
		t.Fatalf("Verify() error = %v, want ErrMissingHeader", err)
	}
}
