func TestProviderNombaMalformedSignatureHeaderRejected(t *testing.T) {
	v := ProviderNomba(nombaGoldenSecret)

	err := v.Verify(nombaGoldenPayload(nil), nombaHeaders("not-valid-base64!!!", nombaGoldenTimestamp))
	if !errors.Is(err, ErrMalformedHeader) {
		t.Fatalf("Verify() error = %v, want ErrMalformedHeader", err)
	}
}

func TestProviderNombaMalformedJSONBodyReturnsDistinctError(t *testing.T) {
	v := ProviderNomba(nombaGoldenSecret)
	body := []byte(`{not valid json`)

	err := v.Verify(body, nombaHeaders(nombaGoldenSignature, nombaGoldenTimestamp))
	if err == nil {
		t.Fatal("Verify() error = nil, want a parse error for malformed JSON")
	}
	if errors.Is(err, ErrInvalidSignature) {
		t.Fatal("Verify() reported malformed JSON as a signature mismatch — these are different failure modes and must be distinguishable")
	}
}

func TestProviderNombaWrongSecretRejected(t *testing.T) {
	v := ProviderNomba("wrong-secret")

	err := v.Verify(nombaGoldenPayload(nil), nombaHeaders(nombaGoldenSignature, nombaGoldenTimestamp))
	if !errors.Is(err, ErrInvalidSignature) {
		t.Fatalf("Verify() error = %v, want ErrInvalidSignature", err)
	}
}
