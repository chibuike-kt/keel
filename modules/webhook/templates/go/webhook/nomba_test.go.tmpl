func TestProviderNombaUnsupportedAlgorithmRejected(t *testing.T) {
	v := ProviderNomba(nombaGoldenSecret)
	h := nombaHeaders(nombaGoldenSignature, nombaGoldenTimestamp)
	h.Set("nomba-signature-algorithm", "HmacSHA512")

	err := v.Verify(nombaGoldenPayload(nil), h)
	if !errors.Is(err, ErrUnsupportedAlgorithm) {
		t.Fatalf("Verify() error = %v, want ErrUnsupportedAlgorithm", err)
	}
}

