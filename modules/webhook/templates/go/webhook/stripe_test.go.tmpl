func TestProviderStripeCustomToleranceRespected(t *testing.T) {
	const secret = "whsec_test"
	body := []byte(`{"id":"evt_1"}`)
	fixedNow := time.Unix(1_700_000_000, 0)
	timestamp := fixedNow.Add(-2 * time.Minute).Unix()

	v := ProviderStripe(secret, WithTolerance(time.Minute)).(*stripeVerifier)
	v.now = func() time.Time { return fixedNow }

	err := v.Verify(body, stripeHeaders(secret, timestamp, body))
	if !errors.Is(err, ErrStaleTimestamp) {
		t.Fatalf("Verify() error = %v, want ErrStaleTimestamp with a 1-minute tolerance", err)
	}
}

func TestProviderStripeMatchesAnyV1DuringSecretRotation(t *testing.T) {
	const oldSecret = "whsec_old"
	const newSecret = "whsec_new"
	body := []byte(`{"id":"evt_1"}`)
	fixedNow := time.Unix(1_700_000_000, 0)
	timestamp := fixedNow.Unix()

	oldSig := stripeSignature(oldSecret, timestamp, body)
	newSig := stripeSignature(newSecret, timestamp, body)
	h := make(http.Header)
	h.Set("Stripe-Signature", fmt.Sprintf("t=%d,v1=%s,v1=%s", timestamp, oldSig, newSig))

	v := ProviderStripe(newSecret).(*stripeVerifier)
	v.now = func() time.Time { return fixedNow }

	if err := v.Verify(body, h); err != nil {
		t.Fatalf("Verify() = %v, want nil (should match the new secret's v1 among several)", err)
	}
}
