func TestProviderStripeTimestampOutsideToleranceRejected(t *testing.T) {
	const secret = "whsec_test"
	body := []byte(`{"id":"evt_1"}`)
	fixedNow := time.Unix(1_700_000_000, 0)
	staleTimestamp := fixedNow.Add(-10 * time.Minute).Unix() // default tolerance is 5m

	v := ProviderStripe(secret).(*stripeVerifier)
	v.now = func() time.Time { return fixedNow }

	err := v.Verify(body, stripeHeaders(secret, staleTimestamp, body))
	if !errors.Is(err, ErrStaleTimestamp) {
		t.Fatalf("Verify() error = %v, want ErrStaleTimestamp", err)
	}
}

