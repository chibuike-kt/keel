package idempotency

import (
	"context"
	"net/http"
	"os"
	"testing"
	"time"

	"github.com/redis/go-redis/v9"
)

// This test exercises RedisStore against a real Redis instance. It is
// skipped unless REDIS_URL is set — CI does not currently run a Redis
// service container, so this test is expected to skip there, not fail;
// wiring up a container is future work, out of scope for this module.
func TestRedisStoreReserveAndComplete(t *testing.T) {
	url := os.Getenv("REDIS_URL")
	if url == "" {
		t.Skip("REDIS_URL not set; skipping Redis-backed idempotency test")
	}

	opts, err := redis.ParseURL(url)
	if err != nil {
		t.Fatalf("redis.ParseURL: %v", err)
	}
	client := redis.NewClient(opts)
	defer client.Close()

	ctx := context.Background()
	if err := client.Ping(ctx).Err(); err != nil {
		t.Fatalf("redis ping: %v", err)
	}

	store := NewRedisStore(client, "keel-test:idempotency:")
	key := "order-" + time.Now().Format("20060102150405.000000000")
	defer client.Del(ctx, "keel-test:idempotency:"+key)

	record, reserved, err := store.Reserve(ctx, key, "hash-a", time.Minute)
	if err != nil {
		t.Fatalf("Reserve: %v", err)
	}
	if !reserved {
		t.Fatal("first Reserve: reserved = false, want true")
	}
	if record.Status != StatusInProgress {
		t.Fatalf("record.Status = %q, want %q", record.Status, StatusInProgress)
	}

	_, reserved, err = store.Reserve(ctx, key, "hash-a", time.Minute)
	if err != nil {
		t.Fatalf("second Reserve: %v", err)
	}
	if reserved {
		t.Fatal("second Reserve: reserved = true, want false (key already exists)")
	}

	resp := StoredResponse{
		StatusCode: http.StatusCreated,
		Headers:    http.Header{"Content-Type": []string{"application/json"}},
		Body:       []byte(`{"id":"order-1"}`),
	}
	if err := store.Complete(ctx, key, resp, time.Hour); err != nil {
		t.Fatalf("Complete: %v", err)
	}

	// Complete must tolerate being called again on an already-completed
	// key — this is the retry-after-crash path.
	if err := store.Complete(ctx, key, resp, time.Hour); err != nil {
		t.Fatalf("second Complete (idempotent): %v", err)
	}

	final, reserved, err := store.Reserve(ctx, key, "hash-a", time.Minute)
	if err != nil {
		t.Fatalf("Reserve after complete: %v", err)
	}
	if reserved {
		t.Fatal("Reserve after complete: reserved = true, want false")
	}
	if final.Status != StatusCompleted {
		t.Fatalf("final.Status = %q, want %q", final.Status, StatusCompleted)
	}
	if final.Response == nil || final.Response.StatusCode != resp.StatusCode || string(final.Response.Body) != string(resp.Body) {
		t.Fatalf("final.Response = %+v, want %+v", final.Response, resp)
	}
	if final.Response.Headers.Get("Content-Type") != "application/json" {
		t.Fatalf("final.Response.Headers = %v", final.Response.Headers)
	}
}
