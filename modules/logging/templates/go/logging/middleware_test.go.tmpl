package logging

import (
	"bytes"
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"strings"
	"testing"
)

func splitLines(s string) []string {
	var lines []string
	for _, line := range strings.Split(s, "\n") {
		if line != "" {
			lines = append(lines, line)
		}
	}
	return lines
}

func TestMiddlewareGeneratesRequestIDWhenAbsent(t *testing.T) {
	var buf bytes.Buffer
	base := New(Production, &buf)

	handler := Middleware(base)(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusOK)
	}))

	req := httptest.NewRequest(http.MethodGet, "/orders", nil)
	rec := httptest.NewRecorder()
	handler.ServeHTTP(rec, req)

	got := rec.Header().Get("X-Request-ID")
	if got == "" {
		t.Fatal("X-Request-ID not set on response")
	}
	if len(got) != 32 {
		t.Fatalf("X-Request-ID = %q, want a 32-character generated ID", got)
	}
}

func TestMiddlewareHonorsIncomingRequestID(t *testing.T) {
	var buf bytes.Buffer
	base := New(Production, &buf)

	handler := Middleware(base)(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusOK)
	}))

	const incomingID = "upstream-gateway-correlation-id"
	req := httptest.NewRequest(http.MethodGet, "/orders", nil)
	req.Header.Set("X-Request-ID", incomingID)
	rec := httptest.NewRecorder()
	handler.ServeHTTP(rec, req)

	// This is the test that actually proves the upstream ID is honored,
	// not overwritten with a freshly generated one.
	if got := rec.Header().Get("X-Request-ID"); got != incomingID {
		t.Fatalf("X-Request-ID = %q, want the incoming value %q reused unchanged", got, incomingID)
	}
}

func TestMiddlewareLoggerInContextCarriesRequestID(t *testing.T) {
	var buf bytes.Buffer
	base := New(Production, &buf)

	handler := Middleware(base)(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		FromContext(r.Context()).Info("inside handler")
		w.WriteHeader(http.StatusOK)
	}))

	const incomingID = "trace-abc-123"
	req := httptest.NewRequest(http.MethodGet, "/orders", nil)
	req.Header.Set("X-Request-ID", incomingID)
	rec := httptest.NewRecorder()
	handler.ServeHTTP(rec, req)

	// Two JSON lines are written: the handler's own line, and the
	// middleware's completion line. Decode each and confirm the
	// request-scoped logger's line actually carries request_id, not just
	// that some logger was present in context.
	found := false
	for _, line := range splitLines(buf.String()) {
		var decoded map[string]any
		if err := json.Unmarshal([]byte(line), &decoded); err != nil {
			t.Fatalf("output line is not valid JSON: %v\nline: %s", err, line)
		}
		if decoded["msg"] == "inside handler" {
			found = true
			if decoded["request_id"] != incomingID {
				t.Fatalf(`handler's log line request_id = %v, want %q`, decoded["request_id"], incomingID)
			}
		}
	}
	if !found {
		t.Fatal(`no log line with msg "inside handler" found — the handler's logger produced no output`)
	}
}

func TestMiddlewareCompletionLineIncludesMethodPathStatusDuration(t *testing.T) {
	var buf bytes.Buffer
	base := New(Production, &buf)

	handler := Middleware(base)(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusCreated)
	}))

	req := httptest.NewRequest(http.MethodPost, "/orders", nil)
	rec := httptest.NewRecorder()
	handler.ServeHTTP(rec, req)

	lines := splitLines(buf.String())
	if len(lines) == 0 {
		t.Fatal("no output written")
	}

	var decoded map[string]any
	if err := json.Unmarshal([]byte(lines[len(lines)-1]), &decoded); err != nil {
		t.Fatalf("completion line is not valid JSON: %v", err)
	}
	if decoded["method"] != http.MethodPost {
		t.Fatalf(`decoded["method"] = %v, want %q`, decoded["method"], http.MethodPost)
	}
	if decoded["path"] != "/orders" {
		t.Fatalf(`decoded["path"] = %v, want "/orders"`, decoded["path"])
	}
	if decoded["status"] != float64(http.StatusCreated) {
		t.Fatalf(`decoded["status"] = %v, want %d`, decoded["status"], http.StatusCreated)
	}
	if _, ok := decoded["duration"]; !ok {
		t.Fatal(`completion line missing "duration" field`)
	}
}
