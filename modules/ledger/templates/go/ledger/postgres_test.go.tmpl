func TestLedgerTransferInsufficientFundsFailsFast(t *testing.T) {
	l, pool := newTestLedger(t)
	ctx := context.Background()

	a := createAccount(t, l, uniqueRef(t, "a"), "USD", false) // starts at 0, no overdraft
	b := createAccount(t, l, uniqueRef(t, "b"), "USD", false)

	ref := uniqueRef(t, "overdraft-attempt")
	err := l.Transfer(ctx, a.ID, b.ID, 100, ref)
	if !errors.Is(err, ErrInsufficientFunds) {
		t.Fatalf("Transfer() error = %v, want ErrInsufficientFunds", err)
	}

	// Proves this was rejected before any write, not rolled back after
	// one: nothing with this reference should exist at all.
	var count int
	if err := pool.QueryRow(ctx, `SELECT count(*) FROM transactions WHERE reference = $1`, ref).Scan(&count); err != nil {
		t.Fatalf("count: %v", err)
	}
	if count != 0 {
		t.Fatalf("transactions with reference %q = %d, want 0", ref, count)
	}
}

func TestPostgresRejectsOverdraftOnDirectUpdate(t *testing.T) {
	l, pool := newTestLedger(t)
	ctx := context.Background()

	a := createAccount(t, l, uniqueRef(t, "a"), "USD", false)

	// Bypasses Go's pre-check entirely — this is what actually proves the
	// database trigger backstops the invariant rather than just Go's Post.
	_, err := pool.Exec(ctx, `UPDATE accounts SET balance = -1 WHERE id = $1`, a.ID)
	if err == nil {
		t.Fatal("UPDATE accounts (direct): error = nil, want the overdraft trigger to reject it")
	}
}

func TestLedgerOverdraftAllowedSucceeds(t *testing.T) {
	l, _ := newTestLedger(t)
	ctx := context.Background()

	a := createAccount(t, l, uniqueRef(t, "a"), "USD", true)
	b := createAccount(t, l, uniqueRef(t, "b"), "USD", true)

	if err := l.Transfer(ctx, a.ID, b.ID, 100, uniqueRef(t, "overdraft")); err != nil {
		t.Fatalf("Transfer: %v", err)
	}

	got, err := l.Balance(ctx, a.ID)
	if err != nil {
		t.Fatalf("Balance(a): %v", err)
	}
	if got != -100 {
		t.Fatalf("balance a = %d, want -100", got)
	}
}

func TestLedgerConcurrentTransfersDoNotDeadlock(t *testing.T) {
	l, _ := newTestLedger(t)
	ctx := context.Background()

	a := createAccount(t, l, uniqueRef(t, "a"), "USD", true)
	b := createAccount(t, l, uniqueRef(t, "b"), "USD", true)

	const n = 20
	const amount = 10

	var wg sync.WaitGroup
	errs := make([]error, n)
	wg.Add(n)
	for i := range n {
		go func(i int) {
			defer wg.Done()

			// Bounded, not indefinite: if the sorted-lock-order design
			// didn't actually prevent deadlocks, this is what turns a hang
			// into a failing test instead of one that never finishes.
			runCtx, cancel := context.WithTimeout(ctx, 10*time.Second)
			defer cancel()

			ref := uniqueRef(t, fmt.Sprintf("race-%d", i))
			if i%2 == 0 {
				errs[i] = l.Transfer(runCtx, a.ID, b.ID, amount, ref)
			} else {
				errs[i] = l.Transfer(runCtx, b.ID, a.ID, amount, ref)
			}
		}(i)
	}
	wg.Wait()

	for i, err := range errs {
		if err != nil {
			t.Fatalf("Transfer #%d: %v (deadlock, timeout, or another failure)", i, err)
		}
	}

	balA, err := l.Balance(ctx, a.ID)
	if err != nil {
		t.Fatalf("Balance(a): %v", err)
	}
	balB, err := l.Balance(ctx, b.ID)
	if err != nil {
		t.Fatalf("Balance(b): %v", err)
	}

	// Equal counts of transfers in each direction, same amount: net effect
	// on each account is zero, and the total across both is conserved.
	if balA != 0 || balB != 0 {
		t.Fatalf("balances = (a=%d, b=%d), want (0, 0) after equal transfers in both directions", balA, balB)
	}
	if balA+balB != 0 {
		t.Fatalf("total balance = %d, want 0 (money not conserved)", balA+balB)
	}
}

func TestLedgerDuplicateReferenceRejected(t *testing.T) {
	l, pool := newTestLedger(t)
	ctx := context.Background()

	a := createAccount(t, l, uniqueRef(t, "a"), "USD", true)
	b := createAccount(t, l, uniqueRef(t, "b"), "USD", true)

	ref := uniqueRef(t, "dup")
	if err := l.Transfer(ctx, a.ID, b.ID, 50, ref); err != nil {
		t.Fatalf("first Transfer: %v", err)
	}

	err := l.Transfer(ctx, a.ID, b.ID, 50, ref)
	if !errors.Is(err, ErrDuplicateReference) {
		t.Fatalf("second Transfer() error = %v, want ErrDuplicateReference", err)
	}

	var entryCount int
	if err := pool.QueryRow(ctx, `
		SELECT count(*) FROM entries e JOIN transactions t ON t.id = e.transaction_id
		WHERE t.reference = $1
	`, ref).Scan(&entryCount); err != nil {
		t.Fatalf("count entries: %v", err)
	}
	if entryCount != 2 {
		t.Fatalf("entries for reference %q = %d, want exactly 2 (from the first, successful Transfer only)", ref, entryCount)
	}

	got, err := l.Balance(ctx, a.ID)
	if err != nil {
		t.Fatalf("Balance(a): %v", err)
	}
	if got != -50 {
		t.Fatalf("balance a = %d, want -50 (only the first transfer should have applied)", got)
	}
}
