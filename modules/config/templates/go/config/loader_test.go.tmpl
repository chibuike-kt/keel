func TestLoaderMustString(t *testing.T) {
	t.Run("present", func(t *testing.T) {
		t.Setenv("K", "value")
		l := &loader{}
		if got := l.mustString("K"); got != "value" {
			t.Fatalf("mustString() = %q, want %q", got, "value")
		}
		if l.err() != nil {
			t.Fatalf("err() = %v, want nil", l.err())
		}
	})

	t.Run("absent", func(t *testing.T) {
		l := &loader{}
		if got := l.mustString("MISSING_KEY_XYZ"); got != "" {
			t.Fatalf("mustString() = %q, want empty", got)
		}
		if l.err() == nil {
			t.Fatal("err() = nil, want an error for a missing required string")
		}
	})
}

