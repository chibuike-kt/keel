func TestLoaderOneOf(t *testing.T) {
	t.Run("valid passes through", func(t *testing.T) {
		l := &loader{}
		got := l.oneOf("ENVIRONMENT", "staging", "development", "staging", "production")
		if got != "staging" {
			t.Fatalf("oneOf() = %q, want %q", got, "staging")
		}
		if l.err() != nil {
			t.Fatalf("err() = %v, want nil", l.err())
		}
	})

	t.Run("invalid errors naming the allowed set", func(t *testing.T) {
		l := &loader{}
		l.oneOf("ENVIRONMENT", "bogus", "development", "staging", "production")
		if l.err() == nil {
			t.Fatal("err() = nil, want an error for a value outside the allowed set")
		}
		msg := l.err().Error()
		for _, want := range []string{"bogus", "development", "staging", "production"} {
			if !strings.Contains(msg, want) {
				t.Fatalf("err() = %q, want it to contain %q", msg, want)
			}
		}
	})
}

func TestLoaderRequire(t *testing.T) {
	t.Run("true passes silently", func(t *testing.T) {
		l := &loader{}
		l.require(true, "should not appear")
		if l.err() != nil {
			t.Fatalf("err() = %v, want nil", l.err())
		}
	})

	t.Run("false appends message", func(t *testing.T) {
		l := &loader{}
		l.require(false, "port out of range")
		if l.err() == nil {
			t.Fatal("err() = nil, want an error")
		}
		if !strings.Contains(l.err().Error(), "port out of range") {
			t.Fatalf("err() = %q, want it to contain the given message", l.err().Error())
		}
	})
}

func TestLoaderErrAggregatesAllProblems(t *testing.T) {
	l := &loader{}
	l.mustString("MISSING_A")
	l.mustInt("MISSING_B")
	l.require(false, "custom problem")

	err := l.err()
	if err == nil {
		t.Fatal("err() = nil, want a combined error for three accumulated problems")
	}

	// This is the test that actually proves aggregation, not just
	// documents the intent: all three problems must be visible in the
	// single returned error, not just the first one encountered.
	msg := err.Error()
	for _, want := range []string{"MISSING_A", "MISSING_B", "custom problem"} {
		if !strings.Contains(msg, want) {
			t.Fatalf("combined error = %q, want it to mention %q", msg, want)
		}
	}

	// errors.Join's result implements Unwrap() []error — confirm the tree
	// actually contains three distinct errors, not one formatted string
	// that happens to contain the right substrings.
	var joined interface{ Unwrap() []error }
	if !errors.As(err, &joined) {
		t.Fatal("combined error does not implement Unwrap() []error — want errors.Join's aggregation, not a single formatted string")
	}
	if got := len(joined.Unwrap()); got != 3 {
		t.Fatalf("combined error unwraps to %d errors, want 3", got)
	}
}

func TestLoaderErrNilWhenNoProblems(t *testing.T) {
	l := &loader{}
	if err := l.err(); err != nil {
		t.Fatalf("err() = %v, want nil", err)
	}
}
