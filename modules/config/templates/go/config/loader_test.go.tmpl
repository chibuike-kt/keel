func TestLoaderMustInt(t *testing.T) {
	t.Run("present valid", func(t *testing.T) {
		t.Setenv("K", "42")
		l := &loader{}
		if got := l.mustInt("K"); got != 42 {
			t.Fatalf("mustInt() = %d, want 42", got)
		}
		if l.err() != nil {
			t.Fatalf("err() = %v, want nil", l.err())
		}
	})

	t.Run("present invalid", func(t *testing.T) {
		t.Setenv("K", "not-a-number")
		l := &loader{}
		l.mustInt("K")
		if l.err() == nil {
			t.Fatal("err() = nil, want an error for an invalid integer")
		}
		if !strings.Contains(l.err().Error(), "K") || !strings.Contains(l.err().Error(), "not-a-number") {
			t.Fatalf("err() = %v, want it to name the key and the invalid value", l.err())
		}
	})

	t.Run("absent required", func(t *testing.T) {
		l := &loader{}
		l.mustInt("MISSING_KEY_XYZ")
		if l.err() == nil {
			t.Fatal("err() = nil, want an error for a missing required int")
		}
	})
}

func TestLoaderGetInt(t *testing.T) {
	t.Run("present valid", func(t *testing.T) {
		t.Setenv("K", "42")
		l := &loader{}
		if got := l.getInt("K", 7); got != 42 {
			t.Fatalf("getInt() = %d, want 42", got)
		}
	})

	t.Run("present invalid still errors", func(t *testing.T) {
		// getInt is "optional with a default," not "best-effort, ignore
		// errors": a present-but-invalid value must still error, not
		// silently fall back to def.
		t.Setenv("K", "not-a-number")
		l := &loader{}
		l.getInt("K", 7)
		if l.err() == nil {
			t.Fatal("err() = nil, want an error for a present-but-invalid int")
		}
	})

	t.Run("absent uses default", func(t *testing.T) {
		l := &loader{}
		if got := l.getInt("MISSING_KEY_XYZ", 7); got != 7 {
			t.Fatalf("getInt() = %d, want default 7", got)
		}
		if l.err() != nil {
			t.Fatalf("err() = %v, want nil", l.err())
		}
	})
}

