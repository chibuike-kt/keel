package reconcile

import (
	"encoding/json"
	"testing"
)

// rec builds a Record inline. Used instead of an elided slice-of-struct
// literal throughout this file: []Record holding an elided Record
// value puts two opening braces directly adjacent in the source text,
// which collides with Go template action delimiters — and every .tmpl
// file in this catalog is parsed as a template at render time
// regardless of whether it uses any template syntax itself. A helper
// call sidesteps the collision entirely rather than depending on every
// future edit to this file remembering to keep braces apart.
func rec(ref string, data any) Record {
	return Record{Reference: ref, Data: data}
}

func TestCompareBothSidesEqualIsMatched(t *testing.T) {
	internal := []Record{rec("ref-1", 100)}
	external := []Record{rec("ref-1", 100)}

	report := Compare(internal, external, func(a, b any) bool { return a == b })

	if len(report.Matched) != 1 {
		t.Fatalf("Matched = %+v, want 1 entry", report.Matched)
	}
	if len(report.Mismatched) != 0 || len(report.MissingInternal) != 0 || len(report.MissingExternal) != 0 {
		t.Fatalf("report = %+v, want only Matched populated", report)
	}
	if report.Matched[0].Internal.Reference != "ref-1" || report.Matched[0].External.Reference != "ref-1" {
		t.Fatalf("Matched pair = %+v, want both sides referencing ref-1", report.Matched[0])
	}
}

func TestCompareBothSidesNotEqualIsMismatched(t *testing.T) {
	internal := []Record{rec("ref-1", 100)}
	external := []Record{rec("ref-1", 200)}

	report := Compare(internal, external, func(a, b any) bool { return a == b })

	if len(report.Mismatched) != 1 {
		t.Fatalf("Mismatched = %+v, want 1 entry", report.Mismatched)
	}
	if len(report.Matched) != 0 || len(report.MissingInternal) != 0 || len(report.MissingExternal) != 0 {
		t.Fatalf("report = %+v, want only Mismatched populated", report)
	}
	if report.Mismatched[0].Internal.Data != 100 || report.Mismatched[0].External.Data != 200 {
		t.Fatalf("Mismatched pair = %+v, want internal=100 external=200", report.Mismatched[0])
	}
}

func TestCompareInternalOnlyIsMissingExternal(t *testing.T) {
	internal := []Record{rec("ref-1", 100)}
	var external []Record

	report := Compare(internal, external, func(a, b any) bool { return a == b })

	if len(report.MissingExternal) != 1 || report.MissingExternal[0].Reference != "ref-1" {
		t.Fatalf("MissingExternal = %+v, want [ref-1]", report.MissingExternal)
	}
	if len(report.Matched) != 0 || len(report.Mismatched) != 0 || len(report.MissingInternal) != 0 {
		t.Fatalf("report = %+v, want only MissingExternal populated", report)
	}
}

func TestCompareExternalOnlyIsMissingInternal(t *testing.T) {
	var internal []Record
	external := []Record{rec("ref-1", 100)}

	report := Compare(internal, external, func(a, b any) bool { return a == b })

	if len(report.MissingInternal) != 1 || report.MissingInternal[0].Reference != "ref-1" {
		t.Fatalf("MissingInternal = %+v, want [ref-1]", report.MissingInternal)
	}
	if len(report.Matched) != 0 || len(report.Mismatched) != 0 || len(report.MissingExternal) != 0 {
